                  "dim": true
                }
              ]
            },
            {
              "title": "Model",
              "accentColor": "accent",
              "content": [
                {
                  "type": "text",
                  "value": "**Reads both. Does the work.**"
                },
                {
                  "type": "text",
                  "value": "Not on disk at all",
                  "dim": true
                }
              ]
            }
          ],
          "callout": {
            "text": "= {success:**a complete application**}",
            "label": "The whole stack",
            "color": "success",
            "leftBar": true
          }
        }
      }
    },
    {
      "text": "The records are data. The schema is the application. The model is the runtime.",
      "image": {
        "type": "slide",
        "slide": {
          "layout": "bigQuote",
          "eyebrow": {
            "label": "The one line to remember"
          },
          "quote": "The records are {primary:data}. The schema is the {accent:application}. The model is the {highlight:runtime}.",
          "author": "Applications Become Data",
          "role": "Part 4 of 6"
        }
      }
    },
    {
      "text": "Some applications are more than record keeping. A ledger must balance. A room can't be double booked. Those rules deserve real code that never guesses. But even then, the shape changes. Traditional software puts the U I on top — the product — with the A P I as a side door. Invert it. The A P I is the product. And two clients call it as peers: a simple screen for you, and the model.",
      "image": {
        "type": "slide",
        "slide": {
          "layout": "comparison",
          "eyebrow": {
            "label": "The inversion"
          },
          "title": "Where does the interface sit?",
          "left": {
            "title": "UI-centric",
            "accentColor": "warning",
            "content": [
              {
                "type": "bullets",
                "items": [
                  "The UI is the product",
                  "The API is a side door"
                ]
              }
            ],
            "footer": "Every SaaS you rent"
          },
          "right": {
            "title": "API-centric",
            "accentColor": "primary",
            "content": [
              {
                "type": "bullets",
                "items": [
                  "One contract: the API",
                  "Two peer clients: the GUI — and the model"
                ]
              }
            ],
            "footer": "A click and a tool call run the same code"
          }
        }
      }
    },
    {
      "text": "Now watch what the inversion buys. Take an accounting app built this way. Ask it: graph my Q three revenue. A chart rises out of the ledger. Simple. Except for one thing.",
      "image": {
        "type": "html_tailwind",
        "html": "<div class=\"w-[1280px] h-[720px] overflow-hidden flex flex-col\" style=\"background: radial-gradient(1200px 700px at 12% -10%, rgba(56,189,248,.16), transparent 60%), radial-gradient(1000px 600px at 100% 0%, rgba(129,140,248,.16), transparent 55%), linear-gradient(160deg,#0A0F24,#111A3A 55%,#16224D); color:#EEF2FF; font-family:Helvetica,Arial,sans-serif\"><div class=\"flex-1 flex items-center justify-center gap-6 px-12 pt-8\"><div class=\"bg-white/5 border border-white/10 rounded-2xl p-6 w-[440px] font-mono text-[13px]\"><div class=\"mb-3 flex items-center justify-between\"><span style=\"color:#9FB0D8\">ledger / journal</span><span class=\"text-[11px]\" style=\"color:#6F7FA0\">the accounting app</span></div><div class=\"flex py-1.5 text-[11px] uppercase\" style=\"color:#6F7FA0;letter-spacing:.08em\"><span class=\"w-14\">date</span><span class=\"flex-1\">account</span><span class=\"w-16 text-right\">debit</span><span class=\"w-16 text-right\">credit</span></div><div class=\"flex py-1.5 border-b border-white/5\"><span class=\"w-14\" style=\"color:#9FB0D8\">07-03</span><span class=\"flex-1\">Sales — wholesale</span><span class=\"w-16 text-right\" style=\"color:#6F7FA0\">—</span><span class=\"w-16 text-right\" style=\"color:#34D399\">4,180</span></div><div class=\"flex py-1.5 border-b border-white/5\"><span class=\"w-14\" style=\"color:#9FB0D8\">07-21</span><span class=\"flex-1\">Accounts receivable</span><span class=\"w-16 text-right\" style=\"color:#38BDF8\">4,180</span><span class=\"w-16 text-right\" style=\"color:#6F7FA0\">—</span></div><div class=\"flex py-1.5 border-b border-white/5\"><span class=\"w-14\" style=\"color:#9FB0D8\">08-09</span><span class=\"flex-1\">Sales — wholesale</span><span class=\"w-16 text-right\" style=\"color:#6F7FA0\">—</span><span class=\"w-16 text-right\" style=\"color:#34D399\">5,420</span></div><div class=\"flex py-1.5 border-b border-white/5\"><span class=\"w-14\" style=\"color:#9FB0D8\">09-14</span><span class=\"flex-1\">Sales — wholesale</span><span class=\"w-16 text-right\" style=\"color:#6F7FA0\">—</span><span class=\"w-16 text-right\" style=\"color:#34D399\">6,730</span></div><div class=\"flex py-1.5\"><span class=\"w-14\" style=\"color:#9FB0D8\">09-28</span><span class=\"flex-1\">Accounts receivable</span><span class=\"w-16 text-right\" style=\"color:#38BDF8\">6,730</span><span class=\"w-16 text-right\" style=\"color:#6F7FA0\">—</span></div></div><div class=\"flex flex-col items-center w-[190px] text-center\"><div class=\"text-5xl\" style=\"color:#38BDF8;text-shadow:0 0 26px rgba(56,189,248,.9)\">→</div><div class=\"mt-3 text-[13px] leading-snug\" style=\"color:#9FB0D8\">the model reads → the shared chart draws</div></div><div class=\"bg-white/5 border border-white/10 rounded-2xl p-6 w-[440px]\"><div class=\"mb-4 flex items-baseline justify-between\"><span class=\"text-[17px] font-semibold\">Q3 revenue</span><span class=\"text-[11px] font-mono\" style=\"color:#6F7FA0\">the shared chart layer</span></div><div class=\"flex items-end justify-around gap-8 px-4\" style=\"height:230px\"><div class=\"flex flex-col items-center flex-1\"><div class=\"font-mono text-[12px] mb-1\" style=\"color:#9FB0D8\">$4.2k</div><div class=\"w-full rounded-t-lg\" style=\"height:120px;background:linear-gradient(180deg,#38BDF8,rgba(56,189,248,.35))\"></div><div class=\"mt-2 text-[13px]\" style=\"color:#9FB0D8\">Jul</div></div><div class=\"flex flex-col items-center flex-1\"><div class=\"font-mono text-[12px] mb-1\" style=\"color:#9FB0D8\">$5.4k</div><div class=\"w-full rounded-t-lg\" style=\"height:155px;background:linear-gradient(180deg,#818CF8,rgba(129,140,248,.35))\"></div><div class=\"mt-2 text-[13px]\" style=\"color:#9FB0D8\">Aug</div></div><div class=\"flex flex-col items-center flex-1\"><div class=\"font-mono text-[12px] mb-1\" style=\"color:#9FB0D8\">$6.7k</div><div class=\"w-full rounded-t-lg\" style=\"height:192px;background:linear-gradient(180deg,#38BDF8,rgba(56,189,248,.35))\"></div><div class=\"mt-2 text-[13px]\" style=\"color:#9FB0D8\">Sep</div></div></div></div></div><div class=\"pb-10 flex justify-center\"><span class=\"px-5 py-2 rounded-full text-[15px]\" style=\"color:#FBBF24;background:rgba(251,191,36,.12);border:1px solid rgba(251,191,36,.4)\">The accounting app ships no chart code.</span></div></div>"
      }
    },
    {
      "text": "That accounting app contains no chart code. Not a charting library. Not one drawing routine. Graphing lives once, at the A I layer, shared by every application. The model read the numbers from one tool, and drew them with another. The workflow, graph my Q three revenue, exists nowhere as code. It's a decision the model makes at runtime.",
      "image": {
        "type": "slide",
        "slide": {
          "layout": "split",
          "eyebrow": {
