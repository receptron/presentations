text x=\"132\" y=\"446\" font-size=\"13\" letter-spacing=\"2\" fill=\"#818CF8\" font-family=\"Helvetica\">ASAKUSA</text>\n<text x=\"118\" y=\"170\" font-size=\"13\" letter-spacing=\"2\" fill=\"#FBBF24\" font-family=\"Helvetica\">GINZA</text>\n<circle cx=\"150\" cy=\"250\" r=\"9\" fill=\"#38BDF8\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"310\" cy=\"250\" r=\"9\" fill=\"#38BDF8\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"620\" cy=\"250\" r=\"9\" fill=\"#38BDF8\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"232\" cy=\"365\" r=\"9\" fill=\"#818CF8\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"668\" cy=\"135\" r=\"9\" fill=\"#818CF8\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"230\" cy=\"132\" r=\"9\" fill=\"#FBBF24\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"430\" cy=\"117\" r=\"9\" fill=\"#FBBF24\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"700\" cy=\"226\" r=\"9\" fill=\"#FBBF24\" stroke=\"#EEF2FF\" stroke-width=\"3.5\"/>\n<circle cx=\"450\" cy=\"250\" r=\"15\" fill=\"#0A0F24\" stroke=\"#EEF2FF\" stroke-width=\"4.5\"/>\n<circle cx=\"450\" cy=\"250\" r=\"6\" fill=\"#EEF2FF\"/>\n<text x=\"150\" y=\"284\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\" text-anchor=\"middle\">Sushi Rin</text>\n<text x=\"310\" y=\"284\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\" text-anchor=\"middle\">Ramen Kaze</text>\n<text x=\"620\" y=\"284\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\" text-anchor=\"middle\">Yakitori En</text>\n<text x=\"472\" y=\"288\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\" font-weight=\"bold\">Bistro Hana</text>\n<text x=\"252\" y=\"371\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\">Kappo Aoi</text>\n<text x=\"688\" y=\"141\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\">Trattoria Sole</text>\n<text x=\"230\" y=\"110\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\" text-anchor=\"middle\">Café Tsuki</text>\n<text x=\"430\" y=\"95\" font-size=\"17\" fill=\"#EEF2FF\" font-family=\"Helvetica\" text-anchor=\"middle\">Izakaya Moku</text>\n</svg>\n<div class=\"absolute bottom-5 right-6 rounded-xl border px-4 py-2 text-[15px]\" style=\"background:rgba(10,15,36,.85); border-color:rgba(159,176,216,.28); color:#9FB0D8\">Lines = neighborhoods &#183; Stations = restaurants</div>\n</div>\n</div>\n</div>"
      }
