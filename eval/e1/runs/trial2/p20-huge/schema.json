{
  "title": "Home Inventory",
  "icon": "inventory_2",
  "dataPath": "data/home-inventory/items",
  "primaryKey": "id",
  "fields": {
    "id": { "type": "string", "label": "ID", "primary": true, "required": true },
    "name": { "type": "string", "label": "Name", "required": true },
    "room": { "type": "string", "label": "Room", "required": true },
    "category": {
      "type": "enum",
      "label": "Category",
      "values": ["Electronics", "Appliances", "Furniture", "Kitchen", "Clothing", "Tools", "Sports & Outdoors", "Decor", "Books & Media", "Other"]
    },
    "purchaseDate": { "type": "date", "label": "Purchase Date" },
    "price": { "type": "money", "label": "Purchase Price", "currency": "USD" },
    "currentValue": { "type": "money", "label": "Estimated Value", "currency": "USD" },
    "warrantyExpires": { "type": "date", "label": "Warranty Expires" },
    "warrantyStatus": {
      "type": "enum",
      "label": "Warranty Status",
      "values": ["active", "handled", "no-warranty"],
      "required": true
    },
    "serialNumber": { "type": "string", "label": "Serial Number" },
    "photo": { "type": "image", "label": "Photo" },
    "receipts": {
      "type": "table",
      "label": "Receipts",
      "of": {
        "description": { "type": "string", "label": "Description" },
        "file": { "type": "string", "label": "File Path" }
      }
    },
    "condition": {
      "type": "enum",
      "label": "Condition (1-5)",
      "values": ["1", "2", "3", "4", "5"]
    },
    "insured": { "type": "boolean", "label": "Insured" },
    "notes": { "type": "text", "label": "Notes" },
    "manualUrl": { "type": "string", "label": "Manual Link" }
  },
  "displayField": "name",
  "completionField": "warrantyStatus",
  "completionDoneValues": ["handled", "no-warranty"],
  "triggerField": "warrantyExpires",
  "triggerLeadDays": 30,
  "calendarField": "warrantyExpires",
  "kanbanField": "category"
}
