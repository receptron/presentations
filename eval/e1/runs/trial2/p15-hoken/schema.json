{
  "title": "保険一覧",
  "icon": "health_and_safety",
  "dataPath": "data/insurance/items",
  "primaryKey": "id",
  "fields": {
    "id": { "type": "string", "label": "ID", "primary": true, "required": true },
    "company": { "type": "string", "label": "保険会社", "required": true },
    "kind": { "type": "string", "label": "種類", "required": true },
    "annualPremium": { "type": "money", "label": "年間保険料", "currency": "JPY" },
    "nextPaymentDate": { "type": "date", "label": "次回の支払日", "required": true },
    "status": { "type": "enum", "label": "支払状況", "values": ["未払い", "支払済み"], "required": true },
    "paid": { "type": "toggle", "label": "支払済み", "field": "status", "onValue": "支払済み", "offValue": "未払い" },
    "memo": { "type": "text", "label": "メモ" }
  },
  "displayField": "company",
  "completionField": "status",
  "completionDoneValues": ["支払済み"],
  "triggerField": "nextPaymentDate",
  "triggerLeadDays": 14,
  "spawn": {
    "when": { "field": "status", "in": ["支払済み"] },
    "every": { "unit": "year", "interval": 1 },
    "carry": ["company", "kind", "annualPremium", "memo"],
    "set": { "status": "未払い" }
  },
  "calendarField": "nextPaymentDate",
  "kanbanField": "status"
}
